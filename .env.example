# ==========================================
# EDUFIN PLATFORM CONFIGURATION TEMPLATE
# ==========================================

# 1. Express Backend Server (server/.env)
PORT=5000
MONGODB_URI=mongodb://localhost:27017/edufin
JWT_ACCESS_SECRET=edufin_jwt_access_secret_key_2026_secure
JWT_REFRESH_SECRET=edufin_jwt_refresh_secret_key_2026_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Third Party Services (Placeholders)
CLOUDINARY_CLOUD_NAME=edufin-cloud
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Razorpay Gateways
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMTP Email Servers
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@edufin.edu

# 2. AI Engine Microservice (ai-engine/.env)
GEMINI_API_KEY=your_gemini_api_key_here
AI_PORT=8000
